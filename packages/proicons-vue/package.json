{
    "name": "@proicons/vue",
    "description": "ProIcons icon library for Vue",
    "version": "4.13.3",
    "type": "module",
    "sideEffects": false,
    "main": "dist/proicons-vue.js",
    "module": "dist/proicons-vue.js",
    "typings": "dist/proicons-vue.d.ts",
    "files": [
        "dist",
        "!dist/*2.js"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "dev": "bun vite",
        "build:tsdown": "bun tsdown",
        "build": "pnpm run build:tsdown",
        "preview": "bun vite preview",
        "icons:build-modules": "bun run ../../bin/addIconFiles.ts -t './bin/vueIconTemplate.ts' --out './src/icons' -i './src/icons.ts' --format ts --clean --lib vue",
        "ci": "pnpm run icons:build-modules && pnpm run build"
    },
    "author": "ProCode Software",
    "license": "MIT",
    "bugs": "https://github.com/ProCode-Software/proicons/issues",
    "repository": {
        "url": "ProCode-Software/proicons",
        "directory": "packages/proicons-vue"
    },
    "homepage": "https://github.com/ProCode-Software/proicons/tree/main/packages/proicons-vue",
    "keywords": [
        "icons",
        "icon-pack",
        "js",
        "feather",
        "lucide",
        "fluent",
        "font awesome",
        "svg",
        "proicons",
        "procode",
        "vue"
    ],
    "peerDependencies": {
        "vue": "^3.5.30"
    },
    "devDependencies": {
        "@proicons/shared": "workspace:*",
        "@vitejs/plugin-vue": "^6.0.5",
        "tsdown": "^0.21.7",
        "typescript": "catalog:typescript-stable",
        "unplugin-vue": "^7.1.1",
        "vite": "catalog:",
        "vue-tsc": "^3.2.6"
    }
}
